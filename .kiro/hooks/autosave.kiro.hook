{
  "version": "1.0.0",
  "enabled": true,
  "name": "Autosave",
  "description": "When I save a file, run the appropriate formatter like Prettier or Black\n",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "When I save a file, run the appropriate formatter like Prettier or Black"
  }
}