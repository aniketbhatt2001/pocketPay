{
  "enabled": true,
  "name": "Format Dart on Save",
  "description": "Runs dart format on any Dart file when it's saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.dart"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "dart format $FILE",
    "timeout": 30
  }
}